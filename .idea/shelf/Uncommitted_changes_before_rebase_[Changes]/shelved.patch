+package com.logistica.application.usecases;
+
+import com.logistica.application.mappers.RutaCerradaEventMapper;
+import com.logistica.domain.enums.EstadoProcesamientoRuta;
+import com.logistica.domain.exceptions.RutaDuplicadaException;
+import com.logistica.domain.models.Ruta;
+import com.logistica.domain.repositories.RutaRepository;
+import com.logistica.domain.repositories.TransportistaRepository;
+import com.logistica.dtos.RutaCerradaEventDTO;
+import org.springframework.stereotype.Service;
+import org.springframework.transaction.annotation.Transactional;
+
+@Service
+public class ProcesarCierreRutaUseCaseImpl implements ProcesarCierreRutaUseCase {
+
+    private final RutaRepository rutaRepository;
+    private final TransportistaRepository transportistaRepository;
+    private final RutaCerradaEventMapper rutaCerradaEventMapper;
+
+    public ProcesarCierreRutaUseCaseImpl(
+            RutaRepository rutaRepository,
+            TransportistaRepository transportistaRepository,
+            RutaCerradaEventMapper rutaCerradaEventMapper) {
+        this.rutaRepository = rutaRepository;
+        this.transportistaRepository = transportistaRepository;
+        this.rutaCerradaEventMapper = rutaCerradaEventMapper;
+    }
+
+    @Override
+    @Transactional
+    public void procesar(RutaCerradaEventDTO eventDTO) {
+        if (rutaRepository.existsById(eventDTO.getRutaId())) {
+            throw new RutaDuplicadaException(eventDTO.getRutaId());
+        }
+
+        Ruta ruta = rutaCerradaEventMapper.toDomain(eventDTO);
+
+        // Handle Transportista
+        var transportista = rutaCerradaEventMapper.toTransportista(eventDTO.getConductor());
+        transportistaRepository.save(transportista);
+        ruta.setTransportista(transportista);
+
+        // Set Paradas
+        eventDTO.getParadas().forEach(paradaDTO -> {
+            var parada = rutaCerradaEventMapper.toParada(paradaDTO);
+            ruta.addParada(parada);
+        });
+
+        // Set processing status
+        if (ruta.getModeloContrato() == null || ruta.getTipoVehiculo() == null) {
+            ruta.setEstadoProcesamiento(EstadoProcesamientoRuta.REQUIERE_REVISION);
+        } else {
+            ruta.setEstadoProcesamiento(EstadoProcesamientoRuta.OK);
+        }
+
+        rutaRepository.save(ruta);
+    }
+}
